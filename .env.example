# Server
PORT=3001
# Required in production: random string, at least 32 characters
JWT_SECRET=your-secret-key-change-in-production

# Set to true only if you need Vercel preview deployments (*.vercel.app)
# ALLOW_VERCEL_PREVIEW=true

# Production frontend origin (set on Render when frontend is on Vercel)
# FRONTEND_URL=https://www.viet.edu.in

# Vercel: frontend only — vercel.json proxies /api to Render (viet-website.onrender.com).
# Render: full stack — set FRONTEND_URL to your custom domain for CORS/admin uploads.

# Supabase (backend - database and server-side storage / signed uploads)
SUPABASE_URL=https://your-project.supabase.co
# SERVICE ROLE KEY — server only. Never commit or put in VITE_* / frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: project URL for local Vite (public object URLs). Anon key is NOT used for uploads.
VITE_SUPABASE_URL=https://your-project.supabase.co
# Do NOT set VITE_SUPABASE_ANON_KEY in frontend/production builds (bakes into the client bundle).
# Uploads use signed URLs + service role. Keep storage policies read-only for anon.

# Optional - Vite proxy override
# VITE_API_URL=http://localhost:3001/api

# Optional - Explore Your Path bg video (set on server or upload via Admin → Intro Video)
# EXPLORE_PATH_VIDEO_URL=https://your-project.supabase.co/storage/v1/object/public/videos/explore-path/bgvideoexp.mp4
# VITE_BGVIDEOEXP_URL=https://your-project.supabase.co/storage/v1/object/public/videos/explore-path/bgvideoexp.mp4
