# Server
PORT=3001
# Required in production: random string, at least 32 characters
JWT_SECRET=your-secret-key-change-in-production

# Set to true only if you need Vercel preview deployments (*.vercel.app)
# ALLOW_VERCEL_PREVIEW=true

# Production frontend origin (Render / custom domain)
# FRONTEND_URL=https://www.vietvsp.com

# Supabase (backend - database and server-side storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Anon key for admin image uploads in production (server passes to browser at runtime)
SUPABASE_ANON_KEY=your-anon-key

# Supabase (frontend - local dev only; Vite reads these when you run npm run dev)
# On Render you can use SUPABASE_ANON_KEY above instead — no rebuild needed.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional - Vite proxy override
# VITE_API_URL=http://localhost:3001/api

# Optional - Explore Your Path bg video (set on server or upload via Admin → Intro Video)
# EXPLORE_PATH_VIDEO_URL=https://your-project.supabase.co/storage/v1/object/public/videos/explore-path/bgvideoexp.mp4
# VITE_BGVIDEOEXP_URL=https://your-project.supabase.co/storage/v1/object/public/videos/explore-path/bgvideoexp.mp4
